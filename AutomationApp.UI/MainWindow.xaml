<Window x:Class="AutomationApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Automation App" Height="450" Width="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        
        <!-- Sélection du jeu -->
        <Label Grid.Row="0" Grid.Column="0" Content="Game:" Margin="5"/>
        <ComboBox x:Name="GameComboBox" Grid.Row="0" Grid.Column="1" Margin="5" MinWidth="200"/>
        
        <!-- Seuil d'argent -->
        <Label Grid.Row="1" Grid.Column="0" Content="Money Threshold:" Margin="5"/>
        <TextBox x:Name="MoneyThresholdBox" Grid.Row="1" Grid.Column="1" Text="1000000" Margin="5"/>
        
        <!-- Boutons de contrôle -->
        <Button x:Name="StartButton" Grid.Row="2" Grid.Column="0" Content="Start" Click="StartButton_Click" Margin="5" Width="100"/>
        <Button x:Name="StopButton" Grid.Row="2" Grid.Column="1" Content="Stop" Click="StopButton_Click" Margin="5" Width="100" IsEnabled="False"/>
        
        <!-- Affichage de l'argent -->
        <Label Grid.Row="3" Grid.Column="0" Content="Current Money:" Margin="5"/>
        <TextBlock x:Name="MoneyText" Grid.Row="3" Grid.Column="1" Text="---" Margin="5" FontSize="16" FontWeight="Bold"/>
        
        <!-- Statut -->
        <Label Grid.Row="4" Grid.Column="0" Content="Status:" Margin="5"/>
        <TextBlock x:Name="StatusText" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Text="Ready" Margin="5" Foreground="Gray"/>
        
    </Grid>
</Window>