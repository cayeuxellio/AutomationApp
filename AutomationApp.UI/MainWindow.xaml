<Window x:Class="AutomationApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Automation App" Height="250" Width="350">
        
        <Window.Resources>
                <Style TargetType="Button">
                        <Setter Property="Background" Value="DarkSlateBlue"/>
                        <Setter Property="Foreground" Value="White"/>
                </Style>
        </Window.Resources>
        <StackPanel Margin="10">
                <Button Content="Run Hardcoded Scenario" Click="OnRunClicked" Margin="0,0,0,25"/>
                <Button Content="Load Scenario from File" Click="OnLoadFromFileClicked" Margin="0,0,0,25"/>
                <Button Content="check screen" Click="TestReadRegion"/>
        </StackPanel>
</Window>